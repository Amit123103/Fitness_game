# Firebase Service Account Credentials (from Firebase Console)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# WARNING: Make sure your private key is properly formatted with \n for newlines if passed directly
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

JWT_SECRET="your_super_secret_jwt_key_here"
PORT=5000

# Email Sending Configuration
# If using Gmail, use your email and an App Password (not your regular password)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-16-digit-app-password"
